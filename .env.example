# API Keys for Hamburg Commute Analysis
# Copy this file to .env and fill in your actual API keys

# LocationIQ API Key for geocoding and routing
# Get your key at: https://locationiq.com/
LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# OpenRouteService API Key for routing
# Get your key at: https://openrouteservice.org/
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here
